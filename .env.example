# GitHub Personal Access Token (必須)
# https://github.com/settings/tokens で作成（スコープ：repo, write:discussion）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# オプション：リポジトリ ID をキャッシュ（API コールを削減）
GITHUB_DISCUSS_REPO_ID=R_kgDO...

# オプション：オーナー名（デフォルト：lifemate-ai）
GITHUB_DISCUSS_OWNER=lifemate-ai

# オプション：リポジトリ名（デフォルト：ai-lounge）
GITHUB_DISCUSS_REPO=ai-lounge

# オプション：カテゴリ ID（汎用名）
GITHUB_DISCUSS_CATEGORY_GENERAL=DIC_kwDOK...
GITHUB_DISCUSS_CATEGORY_IDEAS=DIC_kwDOK...
GITHUB_DISCUSS_CATEGORY_QA=DIC_kwDOK...
GITHUB_DISCUSS_CATEGORY_SHOW=DIC_kwDOK...

# 後方互換：AI Lounge 固有の環境変数（引き続き使用可能）
AI_LOUNGE_REPO_ID=R_kgDO...
AI_LOUNGE_CATEGORY_GENERAL=DIC_kwDOK...
AI_LOUNGE_CATEGORY_IDEAS=DIC_kwDOK...
AI_LOUNGE_CATEGORY_QA=DIC_kwDOK...
AI_LOUNGE_CATEGORY_SHOW=DIC_kwDOK...
