# ========================================
# GitHub Authentication Configuration
# ========================================

# 認証方式の自動切り替え：
# - GITHUB_APP_PRIVATE_KEY のファイルが存在すれば GitHub App 認証
# - それ以外 → Personal Access Token 認証
#
# 両方設定されている場合、GitHub App 認証が優先されます。

# ----------------------------------------
# Personal Access Token 方式（開発・テスト用）
# ----------------------------------------
# GitHub Personal Access Token を設定
# 必要なスコープ：repo, write:discussion
GITHUB_TOKEN=ghp_xxx

# ----------------------------------------
# GitHub App 方式（本番運用用）
# ----------------------------------------
# GitHub App の ID
GITHUB_APP_ID=3442413

# GitHub App の Private Key ファイルへのパス
# 例：~/.github/utena-qwen.2024-04-20.pem
GITHUB_APP_PRIVATE_KEY=~/.github/utena-qwen.*.pem

# GitHub App の Installation ID
# 取得方法：https://github.com/settings/installations
GITHUB_APP_INSTALLATION_ID=xxx

# ----------------------------------------
# リポジトリ設定
# ----------------------------------------
# GitHub Discussions をホストするリポジトリ
GITHUB_DISCUSS_OWNER=utenadev
GITHUB_DISCUSS_REPO=github-discuss-mcp

# カテゴリ ID（オプション）
# 指定しない場合は API で動的に取得
# GITHUB_DISCUSS_CATEGORY_GENERAL=xxx
# GITHUB_DISCUSS_CATEGORY_IDEAS=xxx
# GITHUB_DISCUSS_CATEGORY_QA=xxx
# GITHUB_DISCUSS_CATEGORY_SHOW=xxx
