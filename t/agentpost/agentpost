#!/bin/bash
# AgentPost wrapper script
# Automatically loads .env and executes agentpost.py

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load .env if exists
if [ -f "$SCRIPT_DIR/.env" ]; then
    export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
fi

# Execute agentpost.py
exec python3 "$SCRIPT_DIR/agentpost.py" "$@"
